<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_profile_mb">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardProfile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="50dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp"
            android:paddingTop="55dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Informasi Pendaftar"
                android:textColor="#3D5AFE"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Lengkap"
                android:textColor="#3D5AFE"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profilNama"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nama: "
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:paddingTop="2dp"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NIM Mahasiswa"
                android:textColor="#3D5AFE"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profilNim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NIM: "
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:paddingTop="2dp"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Program Studi"
                android:textColor="#3D5AFE"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profilProdi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Prodi: "
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:paddingTop="2dp"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jenis Kelamin"
                android:textColor="#3D5AFE"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profilKelamin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Jenis Kelamin: "
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:paddingTop="2dp"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hobi"
                android:textColor="#3D5AFE"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profilHobi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hobi: "
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:paddingTop="2dp"
                android:paddingBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnKembali"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="KEMBALI"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="#3D5AFE" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <ImageView
        android:id="@+id/iconProfile"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:scaleType="centerCrop"
        android:src="@drawable/profile_icon_removebg"
        android:layout_marginTop="-45dp"
        android:elevation="10dp"

        app:layout_constraintTop_toTopOf="@id/cardProfile"
        app:layout_constraintStart_toStartOf="@id/cardProfile"
        app:layout_constraintEnd_toEndOf="@id/cardProfile"/>

</androidx.constraintlayout.widget.ConstraintLayout>